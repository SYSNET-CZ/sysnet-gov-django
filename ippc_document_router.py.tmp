ROUTER_TAGS = ['document']

router = APIRouter(tags=ROUTER_TAGS)

@router.get(
    path='/document/trash',
    response_model=DocumentListType,
    summary='Vrací seznam smazaných objektů (Document)',
    responses={'default': {'model': ErrorModel}},
    tags=ROUTER_TAGS,
)
async def get_document_trash(
    api_key: APIKey = Depends(header_scheme),
) -> DocumentListType:
    if not is_api_authorized(key=api_key):
        raise ApiError(code=403, message='Forbidden')
    reply = await DbDocument.find(DbDocument.is_deleted == True).to_list()
    if not reply:
        raise ApiError(code=404, message='Trash is empty')
    return DocumentListType(entries=reply, count=len(reply))

@router.patch(
    path='/document/{identifier}/restore',
    response_model=bool,
    summary='Obnoví smazaný objekt (Document)',
    responses={'default': {'model': ErrorModel}},
    tags=ROUTER_TAGS,
)
async def restore_document(
    identifier: str = Path(...),
    api_key: APIKey = Depends(header_scheme),
) -> bool:
    if not is_api_authorized(key=api_key):
        raise ApiError(code=403, message='Forbidden')
    reply = await DbDocument.by_general_id(genid=identifier, include_deleted=True)
    if not reply:
        raise ApiError(code=404, message='Document not found')
    await reply.restore()
    return True

@router.delete(
    path='/document/trash/empty',
    response_model=bool,
    summary='Vysype koš — definitivně smaže všechny smazané objekty (Document)',
    responses={'default': {'model': ErrorModel}},
    tags=ROUTER_TAGS,
)
async def empty_document_trash(
    api_key: APIKey = Depends(header_scheme),
) -> bool:
    if not is_api_authorized(key=api_key):
        raise ApiError(code=403, message='Forbidden')
    deleted_items = await DbDocument.find(DbDocument.is_deleted == True).to_list()
    for item in deleted_items:
        await item.hard_delete()
    return True


LOGGER.info(f"{__name__} - API router is starting up")


@router.delete(
    path='/document/{identifier}',
    response_model=bool,
    summary='Odstraní jeden dokument IPPC',
    description='Odstraní dokument',
    responses={'default': {'model': ErrorModel}},
    tags=ROUTER_TAGS
)
async def delete_document(
        identifier: Annotated[
            str,
            Path(title='Identifikátor dokumentu IPPC',
                 description='Lze použít UUID (nativní), čj. nebo PID (převzato z Domina)')],
        authorize: Annotated[
            Union[str, None],
            Header(title='Autorizační token (JWT)', description='Zatím neimplementováno')] = None,
        api_key: APIKey = Depends(header_scheme)
, identity: Optional[AuthenticatedUser] = Depends(get_request_identity)) -> Union[bool, ErrorModel]:
    if not is_api_authorized(key=api_key):
        raise ApiError(code=403, message='Forbidden')
    actor = identity.sub if identity else ANONYMOUS
    LOGGER.info(f"User [{actor}] " + f"DELETE /document/{str(identifier)}")
    if not await is_acl_authorized(authorize):
        raise ApiError(code=403, message='Forbidden')
    if identifier in [None, '']:
        raise ApiError(code=400, message='Missing identifier')
    reply = await DbDocument.by_general_id(genid=identifier)
    if reply is None:
        LOGGER.info(f"DELETE /document/{str(identifier)} NOT FOUND")
        raise ApiError(code=404, message=f"Document '{str(identifier)}' not found")
    LOGGER.info(f"DELETE /document/{str(identifier)} FOUND")
    if CONFIG.get('deletion_policy', {}).get('soft_delete_enabled'):
        await reply.soft_delete(deleted_by=identity.sub if identity else ANONYMOUS)
    else:
        await reply.hard_delete()
    return True


@router.get(
    path='/document/{identifier}',
    response_model=DocumentType,
    summary='Vrací jeden dokument IPPC',
    description='Vrátí dokument podle identifikátoru',
    responses={'default': {'model': ErrorModel}},
    tags=ROUTER_TAGS
)
async def get_document(
        identifier: Annotated[
            str,
            Path(title='Identifikátor dokumentu',
                 description='Lze použít UUID (nativní), code. nebo PID (převzato z Domina)')],
        authorize: Annotated[
            Union[str, None],
            Header(title='Autorizační token (JWT)', description='Zatím neimplementováno')] = None,
        api_key: APIKey = Depends(header_scheme)
, identity: Optional[AuthenticatedUser] = Depends(get_request_identity)) -> Union[DocumentType, ErrorModel]:
    if not is_api_authorized(key=api_key):
        raise ApiError(code=403, message='Forbidden')
    LOGGER.info(f"GET /document/{identifier}")
    if not await is_acl_authorized(authorize):
        raise ApiError(code=403, message='Forbidden')
    if identifier in [None, '']:
        raise ApiError(code=400, message='Missing identifier')
    reply = await DbDocument.by_general_id(genid=identifier)
    if reply is not None:
        LOGGER.info(f"GET /document/{identifier}  FOUND: {str(reply.identifier)} ")
        out = reply.document
        return out
    LOGGER.info(f"GET /document/{identifier} NOT FOUND")
    if CONFIG['migration'] and is_valid_pid(identifier):
        reply = await DbDocument.migrate(pid=identifier)
        if reply is not None:
            out = reply.document
            return out
    raise ApiError(code=404, message=f"Not found {identifier}")


@router.get(
    path='/document',
    response_model=DocumentListType,
    summary='Vrací seznam dokumentů IPPC',
    description='Vrátí seznam dokumentů - vhodné pro našeptávač',
    responses={'default': {'model': ErrorModel}},
    tags=ROUTER_TAGS
)
async def get_document_list(
        name: Annotated[
            Union[str, None], Query(title='Vyhledávané jméno', description='Jméno k vyhledání')] = None,
        activity: Annotated[
            Union[str, None], Query(title='Vyhledávaná činnost', description='Činnost k vyhledání')] = None,
        search: Annotated[
            Union[str, None], Query(title='Vyhledávaný text', description='Text k vyhledání')] = None,
        start: Annotated[
            Union[int, None], Query(title='Počáteční dokument na stránce')] = None,
        page_size: Annotated[
            Union[int, None], Query(title='Velikost stránky')] = None,
        page: Annotated[
            Union[int, None], Query(title='Stránka')] = None,
        authorize: Annotated[
            Union[str, None],
            Header(title='Autorizační token (JWT)', description='Zatím neimplementováno')] = None,
        api_key: APIKey = Depends(header_scheme)
, identity: Optional[AuthenticatedUser] = Depends(get_request_identity)) -> Union[DocumentListType, ErrorModel]:
    if not is_api_authorized(key=api_key):
        raise ApiError(code=403, message='Forbidden')
    LOGGER.info('GET /document')
    if not await is_acl_authorized(authorize):
        raise ApiError(code=403, message='Forbidden')
    query, paging, sort = create_query(key=name, activity=activity, search=search, start=start, pagesize=page_size, page=page)
    reply = await DbDocument.by_query(query=query, paging=paging, sort=sort)
    if reply is None or not bool(reply):
        raise ApiError(code=404, message='Nothing found')
    if reply.count == 0:
        raise ApiError(code=404, message='Nothing found')
    return reply


